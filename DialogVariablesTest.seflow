      "definitionId": "dialog.handle",
      "title": "Dismiss next confirm",
      "x": 2250,
      "y": 140,
      "properties": {
        "action": "Dismiss",
        "scope": "Next dialog",
        "delaySeconds": "5",
        "promptText": ""
      }
    },
    {
      "id": "delay_before_confirm",
      "definitionId": "flow.delay",
      "title": "Pause before confirm",
      "x": 2520,
      "y": 140,
      "properties": {
        "seconds": "5"
      }
    },
    {
      "id": "eval_confirm",
      "definitionId": "page.evaluate",
      "title": "Confirm dismissed",
      "x": 2790,
      "y": 140,
      "properties": {
        "code": "confirm('Dismiss this confirm?')",
        "saveVariable": "confirmResult"
      }
    },
    {
      "id": "delay_after_confirm",
      "definitionId": "flow.delay",
      "title": "Pause after confirm",
      "x": 3060,
      "y": 140,
      "properties": {
        "seconds": "5"
      }
    },
    {
      "id": "accept_prompt",
      "definitionId": "dialog.handle",
      "title": "Accept next prompt",
      "x": 3330,
      "y": 140,
      "properties": {
        "action": "Accept",
        "scope": "Next dialog",
        "delaySeconds": "5",
        "promptText": "${missingPrompt:-$title prompt}"
      }
    },
    {
      "id": "delay_before_prompt",
      "definitionId": "flow.delay",
      "title": "Pause before prompt",
      "x": 3600,
      "y": 140,
      "properties": {
        "seconds": "5"
      }
    },
    {
      "id": "eval_prompt",
      "definitionId": "page.evaluate",
      "title": "Prompt with variable",
      "x": 3870,
      "y": 140,
      "properties": {
        "code": "prompt('Enter value', 'default')",
        "saveVariable": "promptResult"
      }
    },
    {
      "id": "delay_after_prompt",
      "definitionId": "flow.delay",
      "title": "Pause after prompt",
      "x": 4140,
      "y": 140,
      "properties": {
        "seconds": "5"
      }
    },
    {
      "id": "check_prompt",
      "definitionId": "flow.if-else",
      "title": "Prompt result is expected",
      "x": 4410,
      "y": 140,
      "properties": {
        "condition": "Value equals",
        "left": "$promptResult",
        "value": "Dialog Title prompt",
        "selector": ""
      }
    },
    {
      "id": "success_stop",
      "definitionId": "flow.stop",
      "title": "Success",
      "x": 4950,
      "y": 80,
      "properties": {}
    },
    {
      "id": "export_variables",
      "definitionId": "variable.export-json",
      "title": "Export test variables",
      "x": 4680,
      "y": 80,
      "properties": {
        "path": "/tmp/dialog_variables_test_vars.json",
        "names": "title\nalertResult\nconfirmResult\npromptResult",
        "includeBuiltIns": "false",
        "createDirectory": "true"
      }
    },
    {
      "id": "failed_stop",
      "definitionId": "flow.fail",
      "title": "Failed",
      "x": 4680,
      "y": 220,
      "properties": {
        "message": "Prompt result was '$promptResult', expected 'Dialog Title prompt'."
      }
    }
