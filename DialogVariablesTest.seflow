      "title": "Pause after page opens",
      "x": 630,
      "y": 140,
      "properties": {
        "seconds": "5"
      }
    },
    {
      "id": "get_title_text",
      "definitionId": "element.get-text",
      "title": "Get title text",
      "x": 900,
      "y": 140,
      "properties": {
        "selector": "#title",
        "saveVariable": "title"
      }
    },
    {
      "id": "accept_alert",
      "definitionId": "dialog.handle",
      "title": "Accept next alert",
      "x": 1170,
      "y": 140,
      "properties": {
        "action": "Accept",
        "scope": "Next dialog",
        "delaySeconds": "5",
        "promptText": ""
      }
    },
    {
      "id": "delay_before_alert",
      "definitionId": "flow.delay",
      "title": "Pause before alert",
      "x": 1440,
      "y": 140,
      "properties": {
        "seconds": "5"
      }
    },
    {
      "id": "eval_alert",
      "definitionId": "page.evaluate",
      "title": "Alert $title",
      "x": 1710,
      "y": 140,
      "properties": {
        "code": "alert('${title:-Untitled}')",
        "saveVariable": "alertResult"
      }
    },
    {
      "id": "delay_after_alert",
      "definitionId": "flow.delay",
      "title": "Pause after alert",
      "x": 1980,
      "y": 140,
      "properties": {
        "seconds": "5"
      }
    },
    {
